{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "type": "row",
      "title": "PostgreSQL",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "PG Active Connections",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "sum(pg_stat_activity_count{state=\"active\"})",
          "legendFormat": "active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "gauge",
      "title": "PG Cache Hit Ratio",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "sum(pg_stat_database_blks_hit{datname=\"efficientai\"}) / (sum(pg_stat_database_blks_hit{datname=\"efficientai\"}) + sum(pg_stat_database_blks_read{datname=\"efficientai\"})) * 100",
          "legendFormat": "hit ratio"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "PG Database Size",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "pg_database_size_bytes{datname=\"efficientai\"}",
          "legendFormat": "size"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1073741824 },
              { "color": "red", "value": 10737418240 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
